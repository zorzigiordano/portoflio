<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Contatti — Giordano Zorzi</title>
  <meta name="description" content="Contatta Giordano Zorzi per opportunità di Alto Apprendistato, collaborazioni e proposte professionali.">
  <meta name="author" content="Giordano Zorzi">
  <link rel="stylesheet" href="index.css">
</head>
<body>

  <!-- ======== NAVBAR ======== -->
  <nav id="navbar">
    <div class="nav-left">
      <a href="index.html" class="nav-logo-text" data-transition>GZ</a>
      <a href="chi-sono.html" class="nav-contact" data-transition>CHI SONO</a>
    </div>
    <a href="contatti.html" class="nav-contact active" data-transition>CONTATTI</a>
  </nav>

  <!-- ======== BACK BUTTON ======== -->
  <a href="index.html" class="back-btn" data-transition>
    <span class="back-arrow">←</span> BACK
  </a>

  <!-- ======== PAGE CONTENT ======== -->
  <div class="page-wrapper">
    <div class="contact-content" style="position: relative;">
      
      <!-- BIO SECTION -->
      <h1 class="contact-title" style="text-align: center;">Presentiamoci.</h1>

      <div style="max-width: 700px; margin: 2rem auto 3rem auto; color: var(--text-eggshell); font-size: 1.15rem; line-height: 1.8; font-weight: 300; text-align: center;">
        <p style="margin-bottom: 1.5rem;">
          Ho 26 anni, Digital Strategist in training. Unisco una solida base teorica in Scienze della Comunicazione con l'approccio orientato ai dati appreso all'ITS ICT Piemonte. Puoi anche <a href="https://drive.google.com/file/d/1eJs6i7PUg0HR-qGbmHHskhm-WXSG8vw9/view?usp=drive_link" target="_blank" style="color: var(--gold-saffron); font-weight: 600; text-decoration: underline;">scaricare il mio CV in formato PDF</a>.
        </p>
        <p style="margin-bottom: 1.5rem;">
          Credo che la strategia digitale sia il perfetto punto d'incontro tra la creatività del copywriting, la precisione del CRM e l'impatto della UX.
        </p>
        <p>
          Sono alla ricerca di un'azienda lungimirante per un percorso di Alto Apprendistato, pronto a trasformare i dati in conversioni reali.
        </p>
      </div>

      <!-- FORM SECTION -->
      <div style="margin-top: 2rem;">
        <form id="contact-form" class="contact-form" action="#" method="POST" novalidate>

          <!-- Name -->
          <div class="form-group">
            <label for="nome">Nome e Cognome / Nome Azienda *</label>
            <input type="text" id="nome" name="nome" autocomplete="name" required>
            <span class="error-message" id="nome-error" role="alert"></span>
          </div>

          <!-- Sector / Motivo Contatto -->
          <div class="form-group">
            <label for="settore">Motivo del Contatto *</label>
            <select id="settore" name="settore" required>
              <option value="" disabled selected>Seleziona il motivo del contatto...</option>
              <option value="apprendistato_agenzia">Proposta di Alto Apprendistato (Agenzia)</option>
              <option value="apprendistato_azienda">Proposta di Alto Apprendistato (Azienda)</option>
              <option value="altro">Altro motivo</option>
            </select>
            <span class="error-message" id="settore-error" role="alert"></span>
          </div>

          <!-- Email -->
          <div class="form-group">
            <label for="email">Email *</label>
            <input type="email" id="email" name="email" autocomplete="email" required>
            <span class="error-message" id="email-error" role="alert"></span>
          </div>

          <!-- Message -->
          <div class="form-group">
            <label for="messaggio">Domande o Richieste (Opzionale)</label>
            <textarea id="messaggio" name="messaggio" rows="4"></textarea>
          </div>

          <!-- Submit -->
          <button type="submit" class="btn-primary btn-submit">VALUTIAMO L'ALTO APPRENDISTATO</button>
        </form>
      </div>

      <!-- Success Overlay -->
      <div id="success-overlay" class="success-overlay" aria-hidden="true">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#f5cb5c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
          <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
        <h3>Messaggio Inviato!</h3>
        <p>Grazie per avermi contattato. Ti risponderò al più presto.</p>
        <a href="index.html" class="btn-primary" data-transition>Torna alla Home</a>
      </div>

    </div>
  </div>

  <footer class="site-footer">
    <div class="footer-left">GZ</div>
    <div class="footer-center">© 2026 All rights reserved</div>
    <div class="footer-right" style="gap: 1.5rem; display: flex; align-items: center;">
      <!-- LinkedIn -->
      <a href="https://www.linkedin.com/in/giordano-zorzi-35bb4b272/" target="_blank" style="text-decoration: none;" aria-label="LinkedIn">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="#0077b5"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
      </a>
      <!-- Instagram -->
      <a href="https://www.instagram.com/rewild_ets/" target="_blank" style="text-decoration: none;" aria-label="Instagram">
        <svg width="28" height="28" viewBox="0 0 24 24">
          <defs>
            <linearGradient id="ig-grad" x1="0%" y1="100%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#f09433" />
              <stop offset="25%" stop-color="#e6683c" />
              <stop offset="50%" stop-color="#dc2743" />
              <stop offset="75%" stop-color="#cc2366" />
              <stop offset="100%" stop-color="#bc1888" />
            </linearGradient>
          </defs>
          <path fill="url(#ig-grad)" d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
      </a>
      <!-- Email -->
      <a href="mailto:zorzigiordano@gmail.com" target="_blank" style="text-decoration: none;" aria-label="Email">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z" fill="#EA4335"/>
        </svg>
      </a>
    </div>
  </footer>
  <!-- ======== SUCCESS OVERLAY ======== -->
  <div id="expand-overlay" class="expand-overlay"></div>

  <!-- ======== Scripts ======== -->
  <script>
    (function () {
      'use strict';

      const overlay = document.getElementById('expand-overlay');
      const TRANSITION_DURATION = 850;

      // Page transition handler
      document.addEventListener('click', function (e) {
        const link = e.target.closest('[data-transition]');
        if (!link) return;
        const href = link.getAttribute('href');
        if (!href || href === '#') return;
        e.preventDefault();
        
        const ox = e.clientX || window.innerWidth / 2, oy = e.clientY || window.innerHeight / 2;
        overlay.style.clipPath = `circle(0px at ${ox}px ${oy}px)`;
        overlay.classList.add('active');
        overlay.offsetHeight;
        overlay.style.clipPath = `circle(200vmax at ${ox}px ${oy}px)`;
        
        setTimeout(() => {
          const isBackBtn = link.classList.contains('back-btn');
          if (isBackBtn && window.history.length > 1 && document.referrer.includes(window.location.hostname)) {
            window.history.back();
          } else {
            window.location.href = href;
          }
        }, TRANSITION_DURATION);
      });

      // Form Validation
      const form = document.getElementById('contact-form');
      const nomeInput = document.getElementById('nome');
      const settoreInput = document.getElementById('settore');
      const emailInput = document.getElementById('email');
      const submitBtn = form ? form.querySelector('button[type="submit"]') : null;

      function checkFormValidity() {
        if (!form || !submitBtn) return;
        let isValid = true;
        [nomeInput, settoreInput, emailInput].forEach(function (input) {
          if (input.hasAttribute('required') && !input.value.trim()) isValid = false;
          if (input.type === 'email' && input.value.trim() && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value.trim())) isValid = false;
        });
        submitBtn.disabled = !isValid;
      }

      function validateField(input) {
        const group = input.closest('.form-group');
        const errorEl = group.querySelector('.error-message');
        let isValid = true;
        let msg = '';

        if (input.hasAttribute('required') && !input.value.trim()) {
          isValid = false;
          if (input.id === 'nome') msg = "Inserisci il tuo nome o quello dell'azienda.";
          else if (input.id === 'settore') msg = "Seleziona un motivo per il contatto.";
          else if (input.id === 'email') msg = "L'indirizzo email è richiesto.";
        } else if (input.type === 'email' && input.value.trim()) {
          if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value.trim())) {
            isValid = false;
            msg = "Inserisci un indirizzo email valido.";
          }
        }

        if (!isValid) {
          group.classList.add('has-error');
          errorEl.textContent = msg;
          input.setAttribute('aria-invalid', 'true');
        } else {
          group.classList.remove('has-error');
          errorEl.textContent = '';
          input.removeAttribute('aria-invalid');
        }
        checkFormValidity();
        return isValid;
      }

      if (form) {
        // Initial check on load
        checkFormValidity();
        
        [nomeInput, settoreInput, emailInput].forEach(function (input) {
          input.addEventListener('blur', function () { validateField(input); });
          input.addEventListener('input', function () {
            const group = input.closest('.form-group');
            if (group.classList.contains('has-error')) {
              if (input.type === 'email') {
                if (/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(input.value.trim())) {
                  group.classList.remove('has-error');
                  input.removeAttribute('aria-invalid');
                }
              } else if (input.value.trim()) {
                group.classList.remove('has-error');
                input.removeAttribute('aria-invalid');
              }
            }
            checkFormValidity();
          });
        });

        settoreInput.addEventListener('change', function () { validateField(settoreInput); });

        form.addEventListener('submit', function (e) {
          e.preventDefault();
          let valid = true;
          [nomeInput, settoreInput, emailInput].forEach(function (input) {
            if (!validateField(input)) valid = false;
          });

          if (valid) {
            submitBtn.textContent = 'INVIANDO...';
            submitBtn.disabled = true;

            setTimeout(function () {
              document.getElementById('success-overlay').classList.add('active');
              document.getElementById('success-overlay').removeAttribute('aria-hidden');
              form.reset();
              submitBtn.textContent = "VALUTIAMO L'ALTO APPRENDISTATO";
              checkFormValidity();
            }, 1200);
          } else {
            var firstInvalid = form.querySelector('[aria-invalid="true"]');
            if (firstInvalid) firstInvalid.focus();
          }
        });
      }
    })();
  </script>

</body>
</html>
